{
    "name": "@bible-web-framework/backend",
    "scripts": {
        "build": "cargo build --release",
        "dev": "cargo run",
        "lint": "cargo clippy -Dwarnings --all-targets && cargo fmt --check",
        "lint:fix": "cargo clippy --all-targets --fix --allow-dirty && cargo fmt",
        "test": "cargo nextest run --all-targets --no-fail-fast"
    }
}